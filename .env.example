# KAYDAN SHIELD — exemple de configuration .env (à recopier en .env)

# ─────────── Django ───────────
DEBUG=True
SECRET_KEY=change-me-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# ─────────── Field encryption (Fernet) ───────────
# Clé Fernet pour chiffrer les champs sensibles en DB (Camera.password, etc).
# OBLIGATOIRE EN PROD — sans cette clé, fallback dérivé du SECRET_KEY (moins sûr).
# Générer une vraie clé :
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# FIELD_ENCRYPTION_KEY=

# ─────────── Base de données ───────────
# Décommenter pour utiliser PostgreSQL/PostGIS (sinon fallback SQLite)
# Format Docker Compose : "db" est le nom du service
# DATABASE_URL=postgresql://kaydan_user:kaydan_password@db:5432/kaydan_shield
# Format local hors-Docker :
# DATABASE_URL=postgresql://kaydan_user:kaydan_password@localhost:5432/kaydan_shield

# ─────────── Redis (Channels + Celery) ───────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=django-db
CELERY_TASK_ALWAYS_EAGER=True   # False en prod

# ─────────── i18n / TZ ───────────
TIME_ZONE=Africa/Abidjan

# ─────────── Stockage S3 / MinIO (prod) ───────────
# AWS_ACCESS_KEY_ID=kaydan_minio
# AWS_SECRET_ACCESS_KEY=kaydan_minio_password
# AWS_STORAGE_BUCKET_NAME=kaydan-shield
# AWS_S3_ENDPOINT_URL=http://minio:9000
# AWS_S3_REGION_NAME=us-east-1

# ─────────── CORS (prod) ───────────
# CORS_ALLOWED_ORIGINS=https://app.kaydangroupe.com

# ─────────── Sentry (optionnel) ───────────
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=production

# ─────────── IA assistant ───────────
# AI_PROVIDER=openai
# AI_MODEL=gpt-4o-mini
# OPENAI_API_KEY=

# ─────────── SSO Keycloak (feature flag) ───────────
SSO_ENABLED=False
SSO_AUTO_CREATE_USER=True
SSO_SYNC_ROLES=True
SSO_DEFAULT_GROUP=kaydan-users
SSO_OFFLINE_CACHE_TTL_HOURS=24

KEYCLOAK_BASE_URL=https://auth.datarium-dev.com
KEYCLOAK_REALM=kaydan

# Renseignés automatiquement depuis KEYCLOAK_BASE_URL/REALM si vides
# OIDC_OP_ISSUER=
# OIDC_OP_AUTHORIZATION_ENDPOINT=
# OIDC_OP_TOKEN_ENDPOINT=
# OIDC_OP_USER_ENDPOINT=
# OIDC_OP_JWKS_ENDPOINT=
# OIDC_OP_LOGOUT_ENDPOINT=

OIDC_RP_CLIENT_ID=kaydan-shield-web
OIDC_RP_CLIENT_SECRET=change-me-shared-with-keycloak
OIDC_RP_SCOPES=openid profile email roles
OIDC_VERIFY_SSL=True

# ─────────── SMS visiteurs ───────────
# SMS_BACKEND=console      # ou twilio / africastalking
# SMS_FROM=KAYDAN
