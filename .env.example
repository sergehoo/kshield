# ═══════════════════════════════════════════════════════════════════
# KAYDAN SHIELD — Exemple .env
# ═══════════════════════════════════════════════════════════════════
# Copier vers .env puis remplir. Voir docs/GO_LIVE.md pour la procédure prod.
#
# Variables OBLIGATOIRES en prod : SECRET_KEY, ALLOWED_HOSTS, DATABASE_URL,
#   REDIS_URL, CORS_ALLOWED_ORIGINS, FIELD_ENCRYPTION_KEY.
# ═══════════════════════════════════════════════════════════════════


# ─────────── Django core ───────────
DEBUG=True                           # False en prod
SECRET_KEY=change-me-in-production   # DOIT être aléatoire prod (50+ caractères)
ALLOWED_HOSTS=localhost,127.0.0.1    # csv, ajouter le domaine prod
LOG_LEVEL=INFO                       # DEBUG dev, INFO prod, WARNING optionnel

# ─────────── Chiffrement des champs sensibles ───────────
# Clé Fernet pour chiffrer Camera.password, LocalAgent.hmac_secret, etc.
# OBLIGATOIRE en prod — générer via :
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=

# ─────────── HTTPS / TLS ───────────
SECURE_SSL_REDIRECT=True             # Redirige HTTP → HTTPS (via SECURE_PROXY_SSL_HEADER)
SECURE_HSTS_SECONDS=31536000         # 1 an d'HSTS ; 0 pour désactiver temporairement
CSP_REPORT_ONLY=False                # True pour tester Content-Security-Policy sans casser

# ─────────── PostgreSQL / PostGIS ───────────
# Format prod (obligatoire) — PostGIS pour geofencing :
DATABASE_URL=postgresql://kaydan_user:CHANGE_ME@db:5432/kaydan_shield
# En dev sans PG, laisser vide → SQLite auto

# ─────────── Redis (Channels + Celery + cache) ───────────
REDIS_URL=redis://shieldredis:6379/0
CELERY_BROKER_URL=redis://shieldredis:6379/0
CELERY_RESULT_BACKEND=django-db
CELERY_TASK_ALWAYS_EAGER=False       # True en dev seulement

# ─────────── Timezone / i18n ───────────
TIME_ZONE=Africa/Abidjan

# ─────────── CORS + CSRF (prod) ───────────
CORS_ALLOWED_ORIGINS=https://kaydanshield.com,https://app.kaydanshield.com
# Django 4+ exige CSRF_TRUSTED_ORIGINS pour toute mutation cross-origin.
# Par défaut, hérite de CORS_ALLOWED_ORIGINS — override ici si besoin.
CSRF_TRUSTED_ORIGINS=https://kaydanshield.com,https://app.kaydanshield.com

# ─────────── Stockage MinIO / S3 (prod) ───────────
# Le stockage `default` bascule sur S3 en prod. En dev, fichiers locaux.
DEFAULT_FILE_STORAGE=storages.backends.s3boto3.S3Boto3Storage
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
AWS_STORAGE_BUCKET_NAME=kaydan-shield
AWS_S3_ENDPOINT_URL=http://shieldminio:9000
AWS_S3_REGION_NAME=us-east-1
MINIO_ROOT_USER=kaydan_minio
MINIO_ROOT_PASSWORD=CHANGE_ME

# ─────────── SMTP (envoi emails) ───────────
EMAIL_HOST=smtp.eu.mailgun.org
EMAIL_PORT=587
EMAIL_HOST_USER=CHANGE_ME
EMAIL_HOST_PASSWORD=CHANGE_ME
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=no-reply@kaydangroupe.com

# ─────────── MQTT / EMQX (comm équipements) ───────────
# EMQX n'accepte plus l'anonyme en prod. Les users MQTT sont créés dans
# le Dashboard EMQX → Access Control → Authentication → Built-in Database.
# Users à créer : kshield-backend, kshield-edge-master, kshield-devices
MQTT_HOST=shieldmqtt                 # Service Docker interne (backend ↔ broker)
MQTT_PORT=1883                       # 1883 = clair interne | 8883 = TLS public
MQTT_USERNAME=kshield-backend        # ← user créé dans EMQX Dashboard (backend)
MQTT_PASSWORD=CHANGE_ME              # ← password copié depuis EMQX
MQTT_TLS=False                       # True en prod avec certs
MQTT_CA_FILE=/etc/kshield/mqtt/ca.crt  # Requis si MQTT_TLS=True
MQTT_CLIENT_ID_PREFIX=kshield-backend
MQTT_KEEPALIVE=60

# Broker MQTT PUBLIC — annoncé aux agents Go via /activate/ + TOML.
# Défaut : dérivé depuis BASE_DOMAIN (mqtt.<domain>) et MQTT_PORT.
MQTT_PUBLIC_HOST=                    # Ex: mqtt.kaydanshield.com
MQTT_PUBLIC_PORT=                    # Ex: 8883 en TLS public / 1883 sinon

# Compte MQTT dédié aux AGENTS (Option A — compte partagé). Créer ce user
# dans le Dashboard EMQX à côté de kshield-backend. Laisser vide pour
# retomber sur MQTT_USERNAME/MQTT_PASSWORD (dev/lab uniquement).
MQTT_AGENT_USERNAME=kshield-edge-master
MQTT_AGENT_PASSWORD=CHANGE_ME_STRONG_32_CHARS
# Anonymous access — laissé à false en prod
EMQX_ALLOW_ANONYMOUS=false
EMQX_NODE_COOKIE=CHANGE_ME_64_CHARS_RANDOM
EMQX_DASHBOARD_USER=admin
EMQX_DASHBOARD_PASSWORD=CHANGE_ME_STRONG_16_CHARS

# ─────────── Sentry (monitoring erreurs) ───────────
SENTRY_DSN=                          # Format https://<key>@<host>/<project_id>
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_RATE=0.05

# ─────────── PostgreSQL HA (Patroni) — voir docker-compose.ha.yml ───────────
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_REPL_PASSWORD=CHANGE_ME_REPL

# ─────────── IA assistant / Shield IA ───────────
AI_PROVIDER=deepseek                 # deepseek | openai | anthropic
AI_MODEL=deepseek-chat
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=

# ─────────── SSO Keycloak (feature flag) ───────────
SSO_ENABLED=False
SSO_AUTO_CREATE_USER=True
SSO_SYNC_ROLES=True
SSO_DEFAULT_GROUP=kaydan-users
SSO_OFFLINE_CACHE_TTL_HOURS=24
KEYCLOAK_BASE_URL=https://auth.datarium-dev.com
KEYCLOAK_REALM=kaydan
OIDC_RP_CLIENT_ID=kaydan-shield-web
OIDC_RP_CLIENT_SECRET=CHANGE_ME
OIDC_RP_SCOPES=openid profile email roles
OIDC_VERIFY_SSL=True

# ─────────── SMS visiteurs ───────────
SMS_BACKEND=console                  # console | twilio | africastalking
SMS_FROM=KAYDAN
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# AT_API_KEY=
# AT_USERNAME=

# ─────────── Rate limiting (django-axes) ───────────
AXES_FAILURE_LIMIT=5
AXES_COOLOFF_TIME=1                  # heures

# ─────────── Back-office ───────────
# En prod, le front React remplace intégralement les templates Django.
# Laisser à False sauf besoin exceptionnel de repli sur les templates.
ADMIN_TEMPLATES_ENABLED=False

# ─────────── Domaine (Traefik / build front) ───────────
BASE_DOMAIN=kaydanshield.com
CERT_RESOLVER=letsencrypt
VERSION=latest
