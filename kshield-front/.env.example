# Backend Django — origine complète OU laisser vide pour utiliser le proxy Vite
VITE_API_BASE_URL=https://api.kaydanshield.com

# En dev, le vite.config.ts proxifie /api → VITE_API_TARGET.
# Utile pour éviter les CORS et bypasser le SSL.
VITE_API_TARGET=https://api.kaydanshield.com

# Intervalle de polling par défaut (ms) — utilisé par useLive()
VITE_LIVE_POLL_MS=15000
